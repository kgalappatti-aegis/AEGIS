# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://aegis:changeme@postgres:5432/aegis

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
NVD_API_KEY=                          # optional — increases rate limit to 50 req/30s
ABUSECH_AUTH_KEY=                     # optional — free from https://auth.abuse.ch/ — enables ThreatFox + MalwareBazaar

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Queue / stream tuning ─────────────────────────────────────────────────────
BATCH_SIZE=10
BLOCK_MS=5000
CLAIM_MIN_IDLE_MS=30000

# ── Ingestion ─────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=300
NVD_RESULTS_PER_PAGE=2000

# ── Triage ────────────────────────────────────────────────────────────────────
TRIAGE_THRESHOLD=0.4
TRIAGE_CONSUMER_NAME=triage-agent-0

# ── Detection ─────────────────────────────────────────────────────────────────
DETECTION_SKIP_LOW=false
DETECTION_CONSUMER_NAME=detection-agent-0

# ── Simulation ────────────────────────────────────────────────────────────────
SIM_THRESHOLD=0.55
SIM_CONSUMER_NAME=simulation-agent-0
CELERY_CONCURRENCY=4

# ── Advisory ──────────────────────────────────────────────────────────────────
ADVISORY_CONSUMER_NAME=advisory-agent-0

# ── Frontend / bridge ports ───────────────────────────────────────────────────
BRIDGE_PORT=8765
DASHBOARD_PORT=8080
UI_PORT=3000
STATS_SAMPLE=2000

# ── MITRE ATT&CK ─────────────────────────────────────────────────────────────
MITRE_STIX_URL=https://raw.githubusercontent.com/mitre-attack/attack-stix-data/master/enterprise-attack/enterprise-attack.json
